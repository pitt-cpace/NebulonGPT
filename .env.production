# Production Environment Configuration
# These variables are used when running the built application

# NOTE: Do NOT hardcode backend URLs for Docker deployments
# The frontend auto-detects the environment and uses appropriate paths:
# - In development: direct connection to localhost:3001
# - In Docker/production: proxy through current host via Nginx

# Ollama API URL (may need to be configured based on deployment)
# REACT_APP_OLLAMA_URL=http://localhost:11434

# Backend API URL (Python FastAPI backend)
# IMPORTANT: Leave commented out to enable auto-detection for Docker/production
# REACT_APP_BACKEND_URL=http://localhost:3001

# WebSocket URLs
# IMPORTANT: Leave commented out to enable auto-detection for Docker/production
# REACT_APP_VOSK_WS_URL=ws://localhost:3001/vosk
# REACT_APP_TTS_WS_URL=ws://localhost:3001/tts

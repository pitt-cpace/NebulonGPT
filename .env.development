# Development Environment Configuration
# These variables are used when running `npm start`

# Ollama API URL (direct connection in development)
REACT_APP_OLLAMA_URL=http://localhost:11434

# Backend API URL (Python FastAPI backend)
REACT_APP_BACKEND_URL=http://localhost:3001

# WebSocket URLs
REACT_APP_VOSK_WS_URL=ws://localhost:3001/vosk
REACT_APP_TTS_WS_URL=ws://localhost:3001/tts

{
  "name": "nebulon-gpt",
  "version": "0.1.0",
  "private": true,
  "main": "electron.js",
  "homepage": "./",
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.13.0",
    "adm-zip": "^0.5.10",
    "axios": "^1.4.0",
    "body-parser": "^1.20.2",
    "canvas": "^3.2.0",
    "concurrently": "^8.0.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^8.0.7",
    "react-router-dom": "^6.11.1",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@types/dom-speech-recognition": "^0.0.4",
    "@types/node": "^16.18.30",
    "@types/pdfjs-dist": "^2.10.378",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "node server.js",
    "start:both": "concurrently \"npm run server\" \"npm start\"",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && node_modules\\.bin\\electron .\"",
    "build:electron": "npm run build && electron-builder",
    "build:docker": "docker build -t nebulon-gpt .",
    "dist": "npm run build && electron-builder --publish=never",
    "dist:mac": "npm run build && npm run bundle-python && cp electron.js build/ && cp preload.js build/ && cp public/vosk-audio-processor.js build/ && electron-builder --mac",
    "bundle-python": "mkdir -p python-bundle/lib/python3.9/site-packages && pip3 install --target python-bundle/lib/python3.9/site-packages --upgrade pip vosk>=0.3.45 websockets>=11.0 torch>=1.9.0 soundfile>=0.12.1 kokoro>=0.7.16 'misaki[en]' numpy huggingface_hub spacy>=3.7.0 phonemizer-fork spacy-curated-transformers num2words espeakng-loader https://github.com/explosion/spacy-models/releases/download/en_core_web_sm-3.8.0/en_core_web_sm-3.8.0-py3-none-any.whl && cp -r /Library/Developer/CommandLineTools/Library/Frameworks/Python3.framework/Versions/3.9/lib/python3.9 python-bundle/lib/ && mkdir -p python-bundle/vosk-server && cp -r Vosk-Server/websocket/* python-bundle/vosk-server/ && mkdir -p python-bundle/kokoro-tts && cp -r Kokoro-TTS-Server/websocket/* python-bundle/kokoro-tts/ && printf '#!/bin/bash\\nSCRIPT_DIR=\"$(dirname \"$0\")\"\\nBUNDLE_PYTHONPATH=\"$SCRIPT_DIR/lib/python3.9/site-packages\"\\nexport PYTHONPATH=\"$BUNDLE_PYTHONPATH:$PYTHONPATH\"\\nexec /usr/bin/python3 \"$@\"\\n' > python-bundle/python3 && chmod +x python-bundle/python3",
    "dist:win": "npm run build && cp electron.js build/ && cp preload.js build/ && cp public/vosk-audio-processor.js build/ && electron-builder --win",
    "dist:linux": "npm run build && cp electron.js build/ && cp preload.js build/ && cp public/vosk-audio-processor.js build/ && electron-builder --linux"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.nebulon.gpt",
    "productName": "NebulonGPT",
    "directories": {
      "output": "dist-electron"
    },
    "generateUpdatesFilesForAllChannels": false,
    "compression": "store",
    "files": [
      "build/**/*",
      "electron.js",
      "preload.js",
      "server.js",
      "package.json",
      "node_modules/extract-zip/**/*"
    ],
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "includeSubNodeModules": true,
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "Vosk-Server/websocket/models",
        "to": "models/vosk",
        "filter": [
          "**/*.zip*"
        ]
      },
      {
        "from": "Kokoro-TTS-Server",
        "to": "models/kokoro",
        "filter": [
          "huggingface-cache.zip.*"
        ]
      },
      {
        "from": "Vosk-Server/websocket",
        "to": "vosk-server"
      },
      {
        "from": "Kokoro-TTS-Server/websocket",
        "to": "kokoro-tts"
      },
      {
        "from": "python-bundle",
        "to": "python-bundle",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/cpace-logo-icon-256.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "public/icon.png",
      "category": "Office",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}

{
  "name": "nebulon-gpt",
  "version": "0.1.0",
  "private": true,
  "main": "electron.js",
  "homepage": "./",
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.13.0",
    "adm-zip": "^0.5.10",
    "axios": "^1.4.0",
    "body-parser": "^1.20.2",
    "canvas": "^3.2.0",
    "concurrently": "^8.0.1",
    "cors": "^2.8.5",
    "electron-is-dev": "^2.0.0",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "js-tiktoken": "^1.0.21",
    "katex": "^0.16.25",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^9.16.0",
    "react-katex": "^3.1.0",
    "react-markdown": "^8.0.7",
    "react-router-dom": "^6.11.1",
    "react-scripts": "5.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-math": "^6.0.0",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@types/dom-speech-recognition": "^0.0.4",
    "@types/katex": "^0.16.7",
    "@types/node": "^16.18.30",
    "@types/pdfjs-dist": "^2.10.378",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "scripts": {
    "start:both": "concurrently \"npm run server\" \"npm start\"",
    "electron-dev-win": "set NODE_ENV=development && npm run bundle-python && concurrently \"npm start\" \"npm run start-python-services\" \"wait-on http://localhost:3000 && node node_modules\\electron\\cli.js .\"",
    "electron-dev-mac": "export NODE_ENV=development && npm run bundle-python && concurrently \"npm start\" \"npm run start-python-services\" \"wait-on http://localhost:3000 && electron .\"",
    "dist:mac-x64": "npm run build && ./build-python-bundle-mac.sh x64 && cp electron.js build/ && cp preload.js build/ && cp public/vosk-audio-processor.js build/ && electron-builder --mac --x64",
    "dist:mac-arm64": "npm run build && ./build-python-bundle-mac.sh arm64 && cp electron.js build/ && cp preload.js build/ && cp public/vosk-audio-processor.js build/ && electron-builder --mac --arm64",
    "dist:win": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File build-python-bundle-win.ps1 -Architecture x64 && copy electron.js build\\ && copy preload.js build\\ && copy public\\vosk-audio-processor.js build\\ && electron-builder --win",
    "bundle-python": "node -e \"const os = require('os'); const { execSync } = require('child_process'); const platform = os.platform(); if (platform === 'win32') { execSync('npm run bundle-python-win', { stdio: 'inherit' }); } else if (platform === 'darwin') { execSync('npm run bundle-python-mac', { stdio: 'inherit' }); } else { console.log('Linux bundle not implemented yet, using system Python'); }\"",
    "bundle-python-mac": "chmod +x build-python-bundle-mac.sh && ./build-python-bundle-mac.sh",
    "bundle-python-win": "powershell -NoProfile -ExecutionPolicy Bypass -File build-python-bundle-win.ps1 -Architecture x64",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "node server.js",
    "electron": "npm run build && set NODE_ENV=production && node node_modules\\electron\\cli.js .",
    "start-python-services": "./start-python-services.sh",
    "build:electron": "npm run build && electron-builder",
    "build:docker": "docker build .",
    "dist": "npm run build && electron-builder --publish=never",
    "dist:linux": "npm run build && cp electron.js build/ && cp preload.js build/ && cp public/vosk-audio-processor.js build/ && electron-builder --linux"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.nebulon.gpt",
    "productName": "NebulonGPT",
    "directories": {
      "output": "dist-electron"
    },
    "generateUpdatesFilesForAllChannels": false,
    "compression": "maximum",
    "files": [
      "build/**/*",
      "electron.js",
      "preload.js",
      "server.js",
      "package.json",
      "node_modules/extract-zip/**/*",
      "installer.nsh"
    ],
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "includeSubNodeModules": true,
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "Vosk-Server/websocket/models",
        "to": "models/vosk",
        "filter": [
          "**/*.zip*"
        ]
      },
      {
        "from": "Kokoro-TTS-Server",
        "to": "models/kokoro",
        "filter": [
          "huggingface-cache.zip.*"
        ]
      },
      {
        "from": "python-bundle.zip",
        "to": "python-bundle.zip"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": "dmg",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": "University of Pittsburgh (BB467SPB6A)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "icon": "public/cpace-logo-icon-256.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "icon": "public/icon.png",
      "category": "Office",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "createStartMenuShortcut": true,
      "createDesktopShortcut": true,
      "menuCategory": false,
      "shortcutName": "${productName}",
      "uninstallDisplayName": "${productName}",
      "installerIcon": "public/cpace-logo-icon-256.ico",
      "uninstallerIcon": "public/cpace-logo-icon-256.ico",
      "installerHeaderIcon": "public/cpace-logo-icon-256.ico",
      "differentialPackage": false,
      "include": "installer.nsh",
      "displayLanguageSelector": false,
      "installerSidebar": "public/cpace-logo.png",
      "uninstallerSidebar": "public/cpace-logo.png",
      "allowElevation": true,
      "perMachine": false,
      "packElevateHelper": true,
      "warningsAsErrors": false,
      "unicode": true
    }
  }
}

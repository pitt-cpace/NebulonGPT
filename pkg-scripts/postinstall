#!/bin/bash

echo "Setting up NebulonGPT resources..." >&2

# Get the user who invoked the installer
CURRENT_USER="${USER}"
if [ "$CURRENT_USER" = "root" ]; then
    CURRENT_USER=$(stat -f "%Su" /dev/console)
fi

USER_HOME=$(eval echo ~$CURRENT_USER)
NEBULON_DIR="$USER_HOME/.nebulon-gpt"
RESOURCES_DIR="/Applications/NebulonGPT.app/Contents/Resources"

echo "Target directory: $NEBULON_DIR" >&2
echo "Current user: $CURRENT_USER" >&2

# Create .nebulon-gpt directory with proper ownership
mkdir -p "$NEBULON_DIR"
chown -R "$CURRENT_USER:staff" "$NEBULON_DIR"

# Track what was installed for final summary

OLLAMA_STATUS="not installed"
MODEL_STATUS=""

# ============================================
# EXTRACT PYTHON BUNDLE (silent - no dialog)
# ============================================

if [ -f "$RESOURCES_DIR/python-bundle.zip" ]; then
    if [ ! -d "$NEBULON_DIR/python-bundle" ]; then
        echo "Extracting Python bundle..." >&2
        osascript -e 'display notification "Extracting Python environment..." with title "NebulonGPT Installer"' 2>/dev/null
        unzip -q "$RESOURCES_DIR/python-bundle.zip" -d "$NEBULON_DIR"
        chown -R "$CURRENT_USER:staff" "$NEBULON_DIR/python-bundle"
    fi
fi

# ============================================
# EXTRACT VOSK MODELS (silent - no dialog)
# ============================================

if [ -d "$RESOURCES_DIR/models/vosk" ]; then
    if [ ! -d "$NEBULON_DIR/vosk-models" ]; then
        echo "Extracting Vosk speech models..." >&2
        osascript -e 'display notification "Installing speech recognition models..." with title "NebulonGPT Installer"' 2>/dev/null
        mkdir -p "$NEBULON_DIR/vosk-models"
        find "$RESOURCES_DIR/models/vosk" -name "*.zip*" -exec cp {} "$NEBULON_DIR/vosk-models/" \;
        cd "$NEBULON_DIR/vosk-models"
        for base in $(ls *.zip.* 2>/dev/null | sed 's/\.zip\..*//' | sort -u); do
            if [ -f "${base}.zip.001" ]; then
                cat ${base}.zip.* > ${base}.zip
                unzip -q ${base}.zip
                rm ${base}.zip*
            fi
        done
        chown -R "$CURRENT_USER:staff" "$NEBULON_DIR/vosk-models"
    fi
fi

# ============================================
# EXTRACT KOKORO TTS CACHE (silent - no dialog)
# ============================================

if [ -d "$RESOURCES_DIR/models/kokoro" ]; then
    if [ ! -d "$NEBULON_DIR/huggingface" ]; then
        echo "Extracting Kokoro TTS cache..." >&2
        osascript -e 'display notification "Installing text-to-speech models..." with title "NebulonGPT Installer"' 2>/dev/null
        mkdir -p "$NEBULON_DIR/huggingface"
        find "$RESOURCES_DIR/models/kokoro" -name "*.zip*" -exec cp {} "$NEBULON_DIR/huggingface/" \;
        cd "$NEBULON_DIR/huggingface"
        for base in $(ls *.zip.* 2>/dev/null | sed 's/\.zip\..*//' | sort -u); do
            if [ -f "${base}.zip.001" ]; then
                cat ${base}.zip.* > ${base}.zip
                unzip -q ${base}.zip -d "$NEBULON_DIR"
                rm ${base}.zip*
            fi
        done
        if [ -d "$NEBULON_DIR/huggingface-cache" ]; then
            mv "$NEBULON_DIR/huggingface-cache"/* "$NEBULON_DIR/huggingface/" 2>/dev/null
            rmdir "$NEBULON_DIR/huggingface-cache" 2>/dev/null
        fi
        chown -R "$CURRENT_USER:staff" "$NEBULON_DIR/huggingface"
    fi
fi

# ============================================
# START OLLAMA AND PULL MODEL
# ============================================

# Read session info from preinstall
CHOSEN_MODEL=""
NEED_DOWNLOAD_MODEL="false"
MODEL_SIZE="varies"

if [ -f "/var/tmp/nebulon-chosen-model.txt" ]; then
    CHOSEN_MODEL=$(cat /var/tmp/nebulon-chosen-model.txt 2>/dev/null)
    echo "Model: $CHOSEN_MODEL" >&2
fi

if [ -f "/var/tmp/nebulon-installer-session.txt" ]; then
    NEED_DOWNLOAD_MODEL=$(grep "NEED_DOWNLOAD_MODEL=" /var/tmp/nebulon-installer-session.txt 2>/dev/null | cut -d'=' -f2)
    MODEL_SIZE=$(grep "MODEL_SIZE=" /var/tmp/nebulon-installer-session.txt 2>/dev/null | cut -d'=' -f2)
    if [ -z "$CHOSEN_MODEL" ]; then
        CHOSEN_MODEL=$(grep "CHOSEN_MODEL=" /var/tmp/nebulon-installer-session.txt 2>/dev/null | cut -d'=' -f2)
    fi
    echo "Need download model: $NEED_DOWNLOAD_MODEL" >&2
fi

# Check if Ollama is installed and running
if [ -d "/Applications/Ollama.app" ]; then
    echo "Ollama is installed, checking status..." >&2
    
    if curl -s --connect-timeout 2 http://127.0.0.1:11434/api/tags > /dev/null 2>&1; then
        echo "Ollama is already running" >&2
        OLLAMA_STATUS="running"
    else
        # Start ollama serve as the current user in background
        echo "Starting Ollama service..." >&2
        sudo -u "$CURRENT_USER" /usr/local/bin/ollama serve > /dev/null 2>&1 &
        
        # Wait for API to be ready (up to 60 seconds)
        echo "Waiting for Ollama to start..." >&2
        for i in {1..60}; do
            if curl -s --connect-timeout 2 http://127.0.0.1:11434/api/tags > /dev/null 2>&1; then
                echo "Ollama is ready" >&2
                OLLAMA_STATUS="running"
                break
            fi
            sleep 1
        done
        
        if [ "$OLLAMA_STATUS" != "running" ]; then
            OLLAMA_STATUS="installed (not running)"
            echo "Warning: Could not start Ollama service" >&2
        fi
    fi
    
    # ============================================
    # DOWNLOAD MODEL (only if marked as needed by preinstall)
    # ============================================
    
    if [ "$NEED_DOWNLOAD_MODEL" = "true" ] && [ -n "$CHOSEN_MODEL" ] && [ "$OLLAMA_STATUS" = "running" ]; then
        echo "Downloading model '$CHOSEN_MODEL'..." >&2
        
        # Create a script to show progress in Terminal
        MODEL_SCRIPT="/tmp/nebulon-download-model.sh"
        DONE_FLAG="/tmp/nebulon-model-done.txt"
        
        rm -f "$DONE_FLAG"
        
        cat > "$MODEL_SCRIPT" << 'MODELSCRIPT'
#!/bin/bash
clear
echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║       NebulonGPT Installer - Downloading AI Model            ║"
echo "╠══════════════════════════════════════════════════════════════╣"
echo "║  Model: __MODEL_NAME__                                       "
echo "║  Size: __MODEL_SIZE__                                        "
echo "║  Please wait while the model downloads...                    ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

/usr/local/bin/ollama pull "__MODEL_NAME__"
EXIT_CODE=$?

echo ""
if [ $EXIT_CODE -eq 0 ]; then
    echo "✅ Model download complete!"
    echo "success" > "__DONE_FLAG__"
else
    echo "❌ Model download failed!"
    echo "failed" > "__DONE_FLAG__"
fi
echo ""
echo "Download complete! This window will close in 2 seconds..."
sleep 2

# Schedule window close to happen after this script exits (prevents "terminate process" warning)
(sleep 1 && osascript -e 'tell application "Terminal" to close front window' 2>/dev/null) &

exit 0
MODELSCRIPT
        
        # Replace placeholders in the script
        sed -i '' "s|__MODEL_NAME__|$CHOSEN_MODEL|g" "$MODEL_SCRIPT"
        sed -i '' "s|__MODEL_SIZE__|$MODEL_SIZE|g" "$MODEL_SCRIPT"
        sed -i '' "s|__DONE_FLAG__|$DONE_FLAG|g" "$MODEL_SCRIPT"
        chmod +x "$MODEL_SCRIPT"
        
        # Open Terminal to show download progress
        osascript <<EOF
tell application "Terminal"
    activate
    do script "$MODEL_SCRIPT"
end tell
EOF
        
        # Wait for model download to complete
        echo "Waiting for model download to complete..." >&2
        PULL_RESULT=1
        for i in {1..7200}; do  # Wait up to 2 hours for large models
            sleep 1
            if [ -f "$DONE_FLAG" ]; then
                if grep -q "success" "$DONE_FLAG" 2>/dev/null; then
                    PULL_RESULT=0
                fi
                break
            fi
        done
        
        # Give user a moment to see the completion message
        sleep 2
        
        # Close the Terminal window from here (after script has exited)
        osascript -e 'tell application "Terminal" to close (first window whose name contains "nebulon")' 2>/dev/null
        
        # Clean up
        rm -f "$MODEL_SCRIPT" "$DONE_FLAG"
        
        if [ $PULL_RESULT -eq 0 ]; then
            echo "Model '$CHOSEN_MODEL' pulled successfully ✓" >&2
            MODEL_STATUS="$CHOSEN_MODEL (installed)"
        else
            echo "Warning: Failed to pull model '$CHOSEN_MODEL'" >&2
            MODEL_STATUS="$CHOSEN_MODEL (download failed)"
            osascript -e "display dialog \"Failed to download AI model: $CHOSEN_MODEL\n\nYou can download it later by running:\nollama pull $CHOSEN_MODEL\" with title \"NebulonGPT Installer\" buttons {\"OK\"} with icon caution" 2>/dev/null
        fi
    elif [ -n "$CHOSEN_MODEL" ]; then
        # Model already exists or not needed
        MODEL_STATUS="$CHOSEN_MODEL (ready)"
    fi
    
    # ============================================
    # LAUNCH GUI APP FOR STATUS BAR ICON
    # ============================================
    
    # Launch GUI app to provide status bar icon (it will connect to the running serve process)
    if [ "$OLLAMA_STATUS" = "running" ]; then
        echo "Launching Ollama GUI app for status bar icon..." >&2
        
        # Use launchctl to properly start Ollama in user context
        sudo -u "$CURRENT_USER" launchctl asuser "$(id -u "$CURRENT_USER")" /usr/bin/open -a "Ollama.app" 2>/dev/null
        
        # Give it a moment to launch
        sleep 2
        
        echo "Ollama GUI app launched" >&2
    fi
else
    echo "Ollama is not installed" >&2
    OLLAMA_STATUS="not installed"
fi

# ============================================
# FINAL COMPLETION DIALOG (ONLY ONCE)
# ============================================

echo "" >&2
echo "NebulonGPT setup complete!" >&2

# Use a flag file to ensure dialog shows only once
DIALOG_FLAG="/var/tmp/nebulon-completion-shown.txt"

if [ ! -f "$DIALOG_FLAG" ]; then
    # Mark that we're showing the dialog
    echo "shown" > "$DIALOG_FLAG"
    
    # Build completion message
    COMPLETION_MSG="NebulonGPT Installation Complete!"

    # Show completion dialog
    osascript <<EOF
display dialog "$COMPLETION_MSG" with title "NebulonGPT Installer" buttons {"OK"} default button "OK"
EOF
fi

# ============================================
# CLEANUP SESSION FILES (keep completion flag for duplicate prevention)
# ============================================

rm -f /var/tmp/nebulon-installer-session.txt
rm -f /var/tmp/nebulon-chosen-model.txt
rm -f /tmp/nebulon-model-progress.txt
# Note: nebulon-completion-shown.txt is NOT deleted here - it will be deleted in preinstall on next installation

# Use Python 3.9 slim image as base
FROM python:3.9-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    wget \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements file
COPY websocket/requirements.txt /app/requirements.txt

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy the entire Vosk-Server directory
COPY . /app/

# Create models directory
RUN mkdir -p /app/websocket/models

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# Expose the Vosk server port
EXPOSE 2700

# Set the working directory to websocket
WORKDIR /app/websocket

# Default command (can be overridden in docker-compose.yml)
CMD ["python", "asr_server_with_models.py", "models"]
